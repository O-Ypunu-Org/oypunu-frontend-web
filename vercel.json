{
  "buildCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"staging\" ]; then npm run build:staging; else npm run build; fi",
  "installCommand": "npm install --legacy-peer-deps --verbose",
  "framework": "angular",
  "outputDirectory": "dist/oypunu-frontend",
  "git": {
    "deploymentEnabled": {
      "develop": false
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
